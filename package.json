{
  "name": "diary-of-madao",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"yarn watch:orm\"  \"next dev\"",
    "build": "next build",
    "start": "next start",
    "clean:dist": "node ./tools/clearBabelDist.js",
    "build:orm": "babel -w ./src --out-dir dist --extensions \".ts,.tsx\"",
    "watch:orm": "run-s clean:dist build:orm",
    "c:table": "typeorm migration:create",
    "m:table": "typeorm migration:run",
    "r:table": "typeorm migration:revert",
    "c:entity": "typeorm entity:create"
  },
  "dependencies": {
    "next": "10.0.7",
    "pg": "^8.5.1",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.2.31"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.0",
    "@babel/core": "^7.13.8",
    "@babel/plugin-proposal-decorators": "^7.13.5",
    "@babel/preset-typescript": "^7.13.0",
    "@types/node": "^14.14.31",
    "@types/react": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^4.17.0",
    "@typescript-eslint/parser": "^4.17.0",
    "concurrently": "^6.0.0",
    "eslint": "^7.21.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-import-resolver-typescript": "^2.4.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "fs-extra": "^9.1.0",
    "npm-run-all": "^4.1.5",
    "scss": "^0.2.4",
    "typescript": "^4.2.2"
  }
}
