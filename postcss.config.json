{
  "plugins": [
    "postcss-flexbugs-fixes",
    [
      "postcss-preset-env",
      {
        "autoprefixer": {
          "flexbox": "no-2009"
        },
        "stage": 3,
        "features": {
          "custom-properties": false
        }
      }
    ],
    [
      "postcss-px-to-viewport",
      {
        "unitToConvert": "px",
        "viewportUnit": "vw",
        "viewportWidth": "1440",
        "viewportHeight": "900",
        "unitPrecision": 5,
        "minPixelValue": 1
      }
    ]
  ]
}